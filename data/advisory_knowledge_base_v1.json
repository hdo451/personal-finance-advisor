  "reporting_principles": {
    "facts": "Datos observados y verificables",
    "inferences": "Conclusiones derivadas con evidencia",
    "recommendations": "Acciones sugeridas con evidencia y guardrails"
  },
  "glossary": {
    "fixed_expenses": "gastos obligatorios recurrentes",
    "variable_expenses": "gastos necesarios pero fluctuantes",
    "discretionary_expenses": "gastos opcionales",
    "savings_rate": "porcentaje de ingreso ahorrado",
    "dti": "proporción de deuda vs ingreso",
    "leakage": "fuga de dinero en pequeños gastos no controlados",
    "burn_rate": "velocidad de consumo de ingresos",
    "cash_flow": "flujo neto de dinero",
    "wealth": "acumulación de activos valiosos, no dinero",
    "assets": "recursos que generan ingreso o retienen valor",
    "liabilities": "obligaciones que consumen ingreso",
    "liquidity": "disponibilidad de capital",
    "debasement": "pérdida de poder adquisitivo",
    "delta_w": "cambio en riqueza = (P + rA) - E",
    "rA": "retorno sobre activos"
  },
